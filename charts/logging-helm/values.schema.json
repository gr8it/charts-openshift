{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "objectBucketClaim": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClassName": { "type": "string", "minLength": 1 },
        "bucketName": { "type": ["string", "null"] }
      }
    },
    "lokistack": {
      "type": "object",
      "required": ["size"],
      "properties": {
        "size": {
          "type": "string",
          "enum": ["1x.demo", "1x.extra-small", "1x.pico", "1x.small", "1x.medium"]
        },
        "storage": {
          "type": "object",
          "properties": {
            "schemas": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["effectiveDate", "version"],
                "properties": {
                  "effectiveDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                  "version": { "type": "string", "enum": ["v11", "v12", "v13"] }
                }
              }
            }
          }
        },
        "storageClassName": { "type": "string", "minLength": 1 },
        "replication": {
          "type": "object",
          "properties": {
            "factor": { "type": "integer", "minimum": 1 },
            "zones": { "type": "array" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "global": {
              "type": "object",
              "properties": {
                "ingestion": {
                  "type": "object",
                  "properties": {
                    "ingestionRate": { "type": "integer", "minimum": 1 },
                    "ingestionBurstSize": { "type": "integer", "minimum": 1 },
                    "perStreamRateLimit": { "type": "integer", "minimum": 1 },
                    "perStreamRateLimitBurst": { "type": "integer", "minimum": 1 }
                  }
                },
                "queries": {
                  "type": "object",
                  "properties": {
                    "queryTimeout": { "type": "string", "pattern": "^\\d+[smh]$" }
                  }
                }
              }
            },
            "retention": {
              "type": "object",
              "properties": {
                "days": { "type": "integer", "minimum": 1, "maximum": 365 },
                "streams": { "type": "array" }
              }
            }
          }
        },
        "rules": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "selector": {
              "type": "object",
              "properties": {
                "matchLabels": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "uiplugin": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "collector": {
      "type": "object",
      "properties": {
        "resources": {
          "type": "object",
          "properties": {
            "limits": {
              "type": "object",
              "properties": {
                "cpu": { "type": ["integer", "string"] },
                "memory": { "type": "string", "pattern": "^\\d+[KMGT]i$" }
              }
            },
            "requests": {
              "type": "object",
              "properties": {
                "cpu": { "type": ["integer", "string"] },
                "memory": { "type": "string", "pattern": "^\\d+[KMGT]i$" }
              }
            }
          }
        }
      }
    },
    "hubForwarding": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "url": { "type": "string" }
      }
    },
    "auditToHub": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "vectorWebhook": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "url": { "type": "string" }
      }
    },
    "pgaudit": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "externalSecret": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "refreshInterval": { "type": "string", "pattern": "^\\d+[smh]$" }
      }
    },
    "hub": {
      "type": "object",
      "properties": {
        "spokeLogforward": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "alertingRules": {
          "type": "object",
          "properties": {
            "customerName": { "type": "string" },
            "acs": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "centralUrl": { "type": "string" },
                "namespaceRegex": { "type": "string" }
              }
            },
            "hwEvents": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" }
              }
            }
          }
        }
      }
    }
  }
}
