{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "userWorkloadMonitoring": {
      "type": "object",
      "properties": {
        "location": { "type": "string" },
        "prometheus": {
          "type": "object",
          "properties": {
            "retention": { "type": "string", "pattern": "^\\d+[smhdwy]$" },
            "storageSize": { "type": "string", "minLength": 1 },
            "storageClassName": { "type": "string", "minLength": 1 },
            "remoteWrite": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "secretName": { "type": "string" },
                "url": { "type": "string" },
                "proxyUrl": { "type": ["string", "null"] }
              }
            }
          }
        },
        "thanosRuler": {
          "type": "object",
          "properties": {
            "storageSize": { "type": "string", "minLength": 1 },
            "storageClassName": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "alertmanager": {
      "type": "object",
      "properties": {
        "eso": { "$ref": "#/$defs/esoConfig" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "backups": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "namespace": { "type": "string" },
        "schedules": { "type": "array" }
      }
    }
  },
  "$defs": {
    "esoConfig": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "refreshInterval": { "type": "string" },
        "vault": {
          "type": "object",
          "properties": {
            "msteamsKey": { "type": "string" },
            "msteamsProperty": { "type": "string" },
            "healthchecksKey": { "type": "string" },
            "healthchecksProperty": { "type": "string" },
            "opsgenieKey": { "type": "string" },
            "opsgenieProperty": { "type": "string" }
          }
        }
      }
    }
  }
}
