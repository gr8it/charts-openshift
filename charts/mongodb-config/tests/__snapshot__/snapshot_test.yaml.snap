          targetPort: 27017
      selector:
        app: eds-mongodb-svc
        statefulset.kubernetes.io/pod-name: eds-mongodb-2
      type: LoadBalancer
  18: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      labels:
        app.kubernetes.io/instance: eds-mongodb
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: mongodb-config
        app.kubernetes.io/version: 1.0.0
        helm.sh/chart: mongodb-config-1.0.0
      name: mongodb-kubernetes-appdb
      namespace: eds
  19: |
    apiVersion: monitoring.coreos.com/v1
    kind: ServiceMonitor
    metadata:
      name: eds-mongodb-svcmon
      namespace: eds
    spec:
      endpoints:
        - basicAuth:
            password:
              key: password
              name: mongodb-monitoring-pwd
            username:
              key: username
              name: mongodb-monitoring-pwd
          interval: 30s
          port: prometheus
          scrapeTimeout: 25s
      namespaceSelector:
        matchNames:
          - eds
      selector:
        matchLabels:
          app: eds-mongodb-svc
