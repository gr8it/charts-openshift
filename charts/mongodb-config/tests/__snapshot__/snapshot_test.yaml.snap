manifests should match snapshot:
  1: |
    apiVersion: cert-manager.io/v1
    kind: Certificate
    metadata:
      labels:
        app.kubernetes.io/instance: eds-mongodb
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: mongodb-config
        app.kubernetes.io/version: 1.0.0
        helm.sh/chart: mongodb-config-1.0.0
      name: eds-mongodb
      namespace: eds
    spec:
      commonName: '*.eds-mongodb-svc.eds.svc.cluster.local'
      dnsNames:
        - '*.eds-mongodb-svc.eds.svc.cluster.local'
        - eds-mongodb-0.service.dev01.cloud.socpoist.sk
        - eds-mongodb-1.service.dev01.cloud.socpoist.sk
        - eds-mongodb-2.service.dev01.cloud.socpoist.sk
      issuerRef:
        group: cert-manager.io
        kind: ClusterIssuer
        name: vault-hub-issuer
      secretName: eds-mongodb-tls
  2: |
    apiVersion: batch/v1
    kind: CronJob
    metadata:
      labels:
        app.kubernetes.io/instance: eds-mongodb
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: mongodb-config
        app.kubernetes.io/version: 1.0.0
        helm.sh/chart: mongodb-config-1.0.0
      name: eds-mongodb-backup
      namespace: eds
    spec:
      concurrencyPolicy: Forbid
      failedJobsHistoryLimit: 7
      jobTemplate:
        spec:
          backoffLimit: 0
          template:
            spec:
              containers:
                - env:
                    - name: RETENTION
                      value: "3"
                    - name: AWS_CA_BUNDLE
                      value: /etc/ssl/certs/service-ca.crt
                    - name: CA_BUNDLE
                      value: /etc/ssl/certs/ca-bundle.crt
                    - name: AWS_ACCESS_KEY_ID
                      valueFrom:
                        secretKeyRef:
                          key: access_key
                          name: eds-mongodb-backup-allinfo
                    - name: AWS_SECRET_ACCESS_KEY
                      valueFrom:
                        secretKeyRef:
                          key: access_key_secret
                          name: eds-mongodb-backup-allinfo
                    - name: S3_BUCKET
                      valueFrom:
                        secretKeyRef:
                          key: bucket
                          name: eds-mongodb-backup-allinfo
                    - name: S3_HOST
                      valueFrom:
                        secretKeyRef:
                          key: endpoint
                          name: eds-mongodb-backup-allinfo
                    - name: AWS_DEFAULT_REGION
                      value: us-east-1
                    - name: MONGODB_USER
                      value: backupUser
                    - name: MONGODB_PWD
                      valueFrom:
                        secretKeyRef:
                          key: password
                          name: mongodb-backup-pwd
                    - name: MONGO_SVC
                      value: eds-mongodb-0.eds-mongodb-svc.eds.svc.cluster.local
                    - name: MONGO_PORT
                      value: "27017"
                    - name: S3INTERNAL
                      value: "true"
                  image: ghcr.io/gr8it/apc-images/mongobackup:latest
                  name: mongodb-backup
                  volumeMounts:
                    - mountPath: /etc/ssl/certs/service-ca.crt
                      name: s3ca
                      subPath: service-ca.crt
                    - mountPath: /etc/ssl/certs/ca-bundle.crt
                      name: ca-bundle
                      subPath: ca-bundle.crt
              restartPolicy: Never
              volumes:
                - configMap:
                    name: openshift-service-ca.crt
                  name: s3ca
                - configMap:
                    name: ca-cert-bundle
                  name: ca-bundle
      schedule: 0 4 * * *
      successfulJobsHistoryLimit: 7
  3: |
    apiVersion: external-secrets.io/v1beta1
    kind: ExternalSecret
    metadata:
      labels:
        app.kubernetes.io/instance: eds-mongodb
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: mongodb-config
        app.kubernetes.io/version: 1.0.0
        helm.sh/chart: mongodb-config-1.0.0
      name: mongodb-admin
      namespace: eds
    spec:
      dataFrom:
        - extract:
            key: dev/eds/mongodb/admin
      refreshInterval: 1h0m0s
      secretStoreRef:
        kind: SecretStore
        name: vault-hub01
      target:
        creationPolicy: Owner
        deletionPolicy: Retain
        name: mongodb-admin-pwd
  4: |
    apiVersion: external-secrets.io/v1beta1
    kind: ExternalSecret
    metadata:
      labels:
        app.kubernetes.io/instance: eds-mongodb
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: mongodb-config
        app.kubernetes.io/version: 1.0.0
        helm.sh/chart: mongodb-config-1.0.0
      name: mongodb-techuser
