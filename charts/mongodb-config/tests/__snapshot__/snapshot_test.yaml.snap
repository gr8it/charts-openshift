      refreshInterval: 1h0m0s
      secretStoreRef:
        kind: SecretStore
        name: vault-hub01
      target:
        creationPolicy: Owner
        deletionPolicy: Retain
        name: mongodb-techuser-pwd
  5: |
    apiVersion: external-secrets.io/v1beta1
