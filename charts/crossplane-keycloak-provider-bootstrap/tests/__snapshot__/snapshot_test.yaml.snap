manifests should match snapshot:
  1: |
    apiVersion: keycloak.m.crossplane.io/v1beta1
    kind: ClusterProviderConfig
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-keycloak-provider-bootstrap
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-keycloak-provider-bootstrap
        helm.sh/chart: crossplane-keycloak-provider-bootstrap-1.0.0
      name: crossplane-keycloak-provider-config
    spec:
      credentials:
        secretRef:
          key: config.json
          name: crossplane-keycloak-provider-config
          namespace: apc-crossplane-system
        source: Secret
  2: |
    apiVersion: external-secrets.io/v1beta1
    kind: ExternalSecret
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-keycloak-provider-bootstrap
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-keycloak-provider-bootstrap
        helm.sh/chart: crossplane-keycloak-provider-bootstrap-1.0.0
        type: provider-credentials
      name: crossplane-keycloak-provider-config
      namespace: apc-crossplane-system
    spec:
      data:
        - remoteRef:
            key: apc-platform/l/keycloak/apps/provisioning
            property: username
          secretKey: username
        - remoteRef:
            key: apc-platform/l/keycloak/apps/provisioning
            property: password
          secretKey: password
      refreshInterval: 1h
      secretStoreRef:
        kind: ClusterSecretStore
        name: vault-hub-secret-store
      target:
        creationPolicy: Owner
        name: crossplane-keycloak-provider-config
        template:
          data:
            config.json: |
              {
                "client_id":"admin-cli",
                "username": "{{ .username }}",
                "password": "{{ .password }}",
                "url": "https://keycloak.apps.example.com/auth",
                "base_path": "",
                "realm": "master",
                "tls_insecure_skip_verify": "false"
