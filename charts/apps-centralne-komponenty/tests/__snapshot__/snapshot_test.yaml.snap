manifests should match snapshot:
  1: |
    apiVersion: openidclient.keycloak.crossplane.io/v1alpha1
    kind: Client
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-xr-functions
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: apps-centralne-komponenty
        helm.sh/chart: apps-centralne-komponenty-1.0.0
      name: bamoe-management-console
    spec:
      deletionPolicy: Delete
      forProvider:
        accessType: PUBLIC
        clientId: bamoe-management-console
        description: bamoe manazment konzola
        frontchannelLogoutEnabled: true
        fullScopeAllowed: false
        name: bamoe
        pkceCodeChallengeMethod: S256
        realmId: apps
        standardFlowEnabled: true
        validRedirectUris: null
      providerConfigRef:
        name: keycloak-config
  2: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-xr-functions
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: apps-centralne-komponenty
        helm.sh/chart: apps-centralne-komponenty-1.0.0
        rbac.authorization.k8s.io/aggregate-to-apc-project-operator: "true"
      name: crossplane-xr-functions-apps-centralne-komponenty-project-operator
    rules:
      - apiGroups:
          - ck.socpoist.sk
        resources:
          - microservices
        verbs:
          - '*'
      - apiGroups:
          - ck.socpoist.sk
        resources:
          - microserviceaccess
        verbs:
          - '*'
  3: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-xr-functions
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: apps-centralne-komponenty
        helm.sh/chart: apps-centralne-komponenty-1.0.0
        rbac.authorization.k8s.io/aggregate-to-apc-project-admin: "true"
      name: crossplane-xr-functions-apps-centralne-komponenty-project-admin
    rules:
      - apiGroups:
          - ck.socpoist.sk
        resources:
          - microservices
        verbs:
          - '*'
      - apiGroups:
          - ck.socpoist.sk
        resources:
          - microserviceaccess
        verbs:
          - '*'
  4: |
    apiVersion: apiextensions.crossplane.io/v1
    kind: Composition
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-xr-functions
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: apps-centralne-komponenty
        helm.sh/chart: apps-centralne-komponenty-1.0.0
      name: crossplane-xr-functions-apps-centralne-komponenty-microservice
    spec:
      compositeTypeRef:
        apiVersion: ck.socpoist.sk/v1alpha1
        kind: Microservice
      mode: Pipeline
      pipeline:
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: openidclient.keycloak.m.crossplane.io/v1alpha1
                kind: Client
                metadata:
                  name: {{ .observed.composite.resource.metadata.name }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: ms-client
                spec:
                  forProvider:
                    realmId: apps
                    clientId: {{ .observed.composite.resource.metadata.name }}
                    name: {{ .observed.composite.resource.metadata.name }}
                    description: {{ .observed.composite.resource.metadata.name }} mikrosluzba
                    accessType: BEARER-ONLY
                    frontchannelLogoutEnabled: true
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: microservice-client
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                {{- range $index, $value := .observed.composite.resource.spec.roles }}
                apiVersion: role.keycloak.m.crossplane.io/v1alpha1
                kind: Role
                metadata:
                  name: {{ $.observed.composite.resource.metadata.name }}-{{ $value }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: ms-client-role-{{ $index }}
                spec:
                  forProvider:
                    realmId: apps
                    name: {{ $value }}
                    clientIdRef:
                      name: {{ $.observed.composite.resource.metadata.name }}
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
                ---
                {{- end }}
            kind: GoTemplate
            source: Inline
          step: microservice-clientroles
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                {{- range  $index, $value := .observed.composite.resource.spec.roles }}
                apiVersion: group.keycloak.m.crossplane.io/v1alpha1
                kind: Group
                metadata:
                  name: apc--ck-{{ $.observed.composite.resource.metadata.name }}-{{ $value }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: ms-client-group-{{ $index }}
                spec:
                  managementPolicies: ["Observe"]
                  forProvider:
                    realmId: apps
                    name: APC--CK-{{ $.observed.composite.resource.metadata.name | upper }}-{{ $value | upper }}
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
                ---
                {{- end }}
            kind: GoTemplate
            source: Inline
          step: microservice-groups
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                {{- range $index, $value := .observed.composite.resource.spec.roles }}
                apiVersion: group.keycloak.m.crossplane.io/v1alpha1
                kind: Roles
                metadata:
                  name: apc--ck-{{ $.observed.composite.resource.metadata.name }}-{{ $value }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: ms-client-group-role-{{ $index }}
                spec:
                  forProvider:
                    realmId: apps
                    groupIdRef:
                      name: apc--ck-{{ $.observed.composite.resource.metadata.name }}-{{ $value }}
                    roleIdsRefs:
                    - name: {{ $.observed.composite.resource.metadata.name }}-admin
                    # not gitopsy!
                    exhaustive: false
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
                ---
                {{- end }}
            kind: GoTemplate
            source: Inline
          step: microservice-group-roles
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: openidclient.keycloak.m.crossplane.io/v1alpha1
                kind: Client
                metadata:
                  name: {{ .observed.composite.resource.metadata.name }}-admin
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: ms-admin-client
                spec:
                  forProvider:
                    realmId: apps
                    clientId: {{ .observed.composite.resource.metadata.name }}-admin
                    name: {{ .observed.composite.resource.metadata.name }}-admin
                    description: {{ .observed.composite.resource.metadata.name }} admin mikrosluzba
                    accessType: PUBLIC
                    standardFlowEnabled: true
                    {{- if or .observed.composite.resource.spec.rootUrl .observed.composite.resource.spec.baseUrl }}
                    rootUrl: {{ .observed.composite.resource.spec.rootUrl | default .observed.composite.resource.spec.baseUrl }}
                    {{- end }}
                    {{- if .observed.composite.resource.spec.baseUrl }}
                    baseUrl: {{ default .observed.composite.resource.spec.baseUrl }}
                    {{- end }}
                    validRedirectUris:
                      {{- range .observed.composite.resource.spec.validRedirectUris }}
                      - {{ . }}
                      {{- end }}
                    {{- if .observed.composite.resource.spec.webOrigins }}
                    webOrigins:
                      {{- range .observed.composite.resource.spec.webOrigins }}
                      - {{ . }}
                      {{- end }}
                    {{- end }}
                    frontchannelLogoutEnabled: true
                    pkceCodeChallengeMethod: S256
                    fullScopeAllowed: false
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: microservice-admin-client
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                {{- range $index, $value := .observed.composite.resource.spec.roles }}
                apiVersion: client.keycloak.m.crossplane.io/v1alpha1
                kind: RoleMapper
                metadata:
                  name: {{ $.observed.composite.resource.metadata.name }}-admin-{{ $.observed.composite.resource.metadata.name }}-{{ $value }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: ms-admin-client-rolemapper-{{ $index }}
                spec:
                  forProvider:
                    realmId: apps
                    clientIdRef:
                      name: {{ $.observed.composite.resource.metadata.name }}-admin
                    roleIdRef:
                      name: {{ $.observed.composite.resource.metadata.name }}-{{ $value }}
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
                ---
                {{- end }}
            kind: GoTemplate
            source: Inline
          step: microservice-admin-rolemappers
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: client.keycloak.m.crossplane.io/v1alpha1
                kind: ProtocolMapper
                metadata:
                  name: {{ .observed.composite.resource.metadata.name }}-admin-audience-{{ .observed.composite.resource.metadata.name }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: ms-admin-client-protocolmapper
                spec:
                  forProvider:
                    realmId: apps
                    clientIdRef:
                      name: {{ $.observed.composite.resource.metadata.name }}-admin
                    protocol: openid-connect
                    protocolMapper: oidc-audience-mapper
                    name: add {{ $.observed.composite.resource.metadata.name }} audience
                    # https://github.com/keycloak/keycloak/blob/0f01444543cf5e755b13a62c233a5c9feef72888/services/src/main/java/org/keycloak/protocol/oidc/mappers/OIDCAttributeMapperHelper.java#L60
                    config:
                      "included.client.audience": "{{ $.observed.composite.resource.metadata.name }}"
                      "access.token.claim": "true"
                      "introspection.token.claim": "true"
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: microservice-admin-protocolmapper
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: openidclient.keycloak.m.crossplane.io/v1alpha1
                kind: Client
                metadata:
                  name: bamoe-management-console
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: bamoe-client
                spec:
                  managementPolicies: ["Observe"]
                  forProvider:
                    realmId: apps
                    clientId: bamoe-management-console
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: bamoe-client
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                {{- range $index, $value := .observed.composite.resource.spec.roles }}
                apiVersion: client.keycloak.m.crossplane.io/v1alpha1
                kind: RoleMapper
                metadata:
                  name: bamoe-{{ $.observed.composite.resource.metadata.name }}-{{ $value }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: bamoe-client-rolemapper-{{ $index }}
                spec:
                  forProvider:
                    realmId: apps
                    clientIdRef:
                      name: bamoe-management-console
                    roleIdRef:
                      name: {{ $.observed.composite.resource.metadata.name }}-{{ $value }}
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
                ---
                {{- end }}
            kind: GoTemplate
            source: Inline
          step: bamoe-rolemappers
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: client.keycloak.m.crossplane.io/v1alpha1
                kind: ProtocolMapper
                metadata:
                  name: bamoe-audience-{{ .observed.composite.resource.metadata.name }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: bamoe-client-protocolmapper
                spec:
                  forProvider:
                    realmId: apps
                    clientIdRef:
                      name: bamoe-management-console
                    protocol: openid-connect
                    protocolMapper: oidc-audience-mapper
                    name: add {{ .observed.composite.resource.metadata.name }} audience
                    # https://github.com/keycloak/keycloak/blob/0f01444543cf5e755b13a62c233a5c9feef72888/services/src/main/java/org/keycloak/protocol/oidc/mappers/OIDCAttributeMapperHelper.java#L60
                    config:
                      "included.client.audience": "{{ .observed.composite.resource.metadata.name }}"
                      "access.token.claim": "true"
                      "introspection.token.claim": "true"
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: bamoe-protolmapper
        - functionRef:
            name: crossplane-xr-functions-auto-ready
          step: automatically-detect-readiness
  5: |
    apiVersion: apiextensions.crossplane.io/v1
    kind: Composition
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-xr-functions
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: apps-centralne-komponenty
        helm.sh/chart: apps-centralne-komponenty-1.0.0
      name: crossplane-xr-functions-apps-centralne-komponenty-microserviceaccess
    spec:
      compositeTypeRef:
        apiVersion: ck.socpoist.sk/v1alpha1
        kind: Microserviceaccess
      mode: Pipeline
      pipeline:
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: openidclient.keycloak.m.crossplane.io/v1alpha1
                kind: Client
                metadata:
                  name: {{ .observed.composite.resource.metadata.name }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: msa-client
                spec:
                  managementPolicies: ["Observe"]
                  forProvider:
                    realmId: apps
                    clientId: {{ .observed.composite.resource.metadata.name }}
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: isas-client
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: client.keycloak.m.crossplane.io/v1alpha1
                kind: RoleMapper
                metadata:
                  name: {{ .observed.composite.resource.metadata.name }}-{{ .observed.composite.resource.spec.clientId }}-{{ .observed.composite.resource.spec.clientRole }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: msa-client-rolemapper
                spec:
                  forProvider:
                    realmId: apps
                    clientIdRef:
                      name: {{ .observed.composite.resource.metadata.name }}
                    roleIdRef:
                      name: {{ .observed.composite.resource.spec.clientId }}-{{ .observed.composite.resource.spec.clientRole }}
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: isas-rolemapper
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: client.keycloak.m.crossplane.io/v1alpha1
                kind: ProtocolMapper
                metadata:
                  name: {{ .observed.composite.resource.metadata.name }}-audience-{{ .observed.composite.resource.spec.clientId }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: msa-client-protocolmapper
                spec:
                  forProvider:
                    realmId: apps
                    clientIdRef:
                      name: {{ .observed.composite.resource.metadata.name }}
                    protocol: openid-connect
                    protocolMapper: oidc-audience-mapper
                    name: add {{ .observed.composite.resource.spec.clientId }} audience
                    # https://github.com/keycloak/keycloak/blob/0f01444543cf5e755b13a62c233a5c9feef72888/services/src/main/java/org/keycloak/protocol/oidc/mappers/OIDCAttributeMapperHelper.java#L60
                    config:
                      "included.client.audience": "{{ .observed.composite.resource.spec.clientId }}"
                      "access.token.claim": "true"
                      "introspection.token.claim": "true"
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: microservice-admin-protocolmapper
        - functionRef:
            name: crossplane-xr-functions-go-templating
          input:
            apiVersion: gotemplating.fn.crossplane.io/v1beta1
            inline:
              template: |
                apiVersion: openidclient.keycloak.m.crossplane.io/v1alpha1
                kind: ClientServiceAccountRole
                metadata:
                  name: {{ .observed.composite.resource.metadata.name }}-{{ .observed.composite.resource.spec.clientId }}-{{ .observed.composite.resource.spec.clientRole }}
                  annotations:
                    gotemplating.fn.crossplane.io/composition-resource-name: msa-clientserviceaccountrole
                spec:
                  forProvider:
                    realmId: apps
                    serviceAccountUserClientIdRef:
                      name: {{ .observed.composite.resource.metadata.name }}
                    clientIdRef:
                      name: {{ .observed.composite.resource.spec.clientId }}
                    role: {{ .observed.composite.resource.spec.clientRole }}
                  providerConfigRef:
                    name: keycloak-config
                    kind: ClusterProviderConfig
            kind: GoTemplate
            source: Inline
          step: bamoe-client
        - functionRef:
            name: crossplane-xr-functions-auto-ready
          step: automatically-detect-readiness
  6: |
    apiVersion: apiextensions.crossplane.io/v2
    kind: CompositeResourceDefinition
    metadata:
      name: microservices.ck.socpoist.sk
    spec:
      group: ck.socpoist.sk
      names:
        kind: Microservice
        plural: microservices
        shortNames:
          - ms
      scope: Namespaced
      versions:
        - name: v1alpha1
          referenceable: true
          schema:
            openAPIV3Schema:
              description: Microservice represents a microservice in the system, defined by its Keycloak client configuration
              properties:
                apiVersion:
                  description: 'APIVersion defines the versioned schema of this representation of an object. Servers should convert recognized schemas to the latest internal value, and may reject unrecognized values. More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#resources'
                  type: string
                kind:
                  description: 'Kind is a string value representing the REST resource this object represents. Servers may infer this from the endpoint the client submits requests to. Cannot be updated. In CamelCase. More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#types-kinds'
                  type: string
                metadata:
                  type: object
                spec:
                  description: Defines the microservice
                  properties:
                    baseUrl:
                      description: Base URL of the microservice Keycloak client, used as a default redirect
                      type: string
                    roles:
                      description: List of microservice Keycloak roles
                      items:
                        type: string
                      type: array
                    rootUrl:
                      description: Root URL of the microservice Keycloak client, prepended to all relative URLs
                      type: string
                    validRedirectUris:
                      description: List of Keycloak client allowed redirect URIs
                      items:
                        type: string
                      type: array
                    webOrigins:
                      description: List of Keycloak client allowed web origins, allowed CORS origins. To permit all origins of Valid Redirect URIs, add '+'. This does not include the '*' wildcard though. To permit all origins, explicitly add '*'.
                      items:
                        type: string
                      type: array
                  required:
                    - roles
                    - validRedirectUris
                  type: object
              required:
                - spec
              type: object
          served: true
  7: |
    apiVersion: apiextensions.crossplane.io/v2
    kind: CompositeResourceDefinition
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-xr-functions
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: apps-centralne-komponenty
        helm.sh/chart: apps-centralne-komponenty-1.0.0
      name: microserviceaccesses.ck.socpoist.sk
    spec:
      group: ck.socpoist.sk
      names:
        kind: Microserviceaccess
        plural: microserviceaccesses
        shortNames:
          - msa
      scope: Namespaced
      versions:
        - name: v1alpha1
          referenceable: true
          schema:
            openAPIV3Schema:
              description: Microserviceaccess allows management of access to a microservice
              properties:
                apiVersion:
                  description: 'APIVersion defines the versioned schema of this representation of an object. Servers should convert recognized schemas to the latest internal value, and may reject unrecognized values. More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#resources'
                  type: string
                kind:
                  description: 'Kind is a string value representing the REST resource this object represents. Servers may infer this from the endpoint the client submits requests to. Cannot be updated. In CamelCase. More info: https://git.k8s.io/community/contributors/devel/sig-architecture/api-conventions.md#types-kinds'
                  type: string
                metadata:
                  type: object
                spec:
                  description: Defines access to a microservice
                  properties:
                    clientId:
                      description: Keycloak client name of the microservice to assume the role for
                      type: string
                    clientRole:
                      description: Keycloak client role to assume for the microservice access client
                      type: string
                  required:
                    - clientRole
                    - clientId
                  type: object
              required:
                - spec
              type: object
          served: true
