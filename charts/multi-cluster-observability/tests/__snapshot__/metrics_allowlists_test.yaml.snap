renders hub allowlists without spoke-only Kafka configmap:
  1: |
    apiVersion: v1
    data:
      metrics_list.yaml: |
        names:
          - kube_namespace_labels
          - ocs_rgw_health_status
          - odf_system_health_status
          - ceph_health_status
          - kube_pod_labels
          - kube_secret_owner
          - kube_persistentvolumeclaim_info
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: observability-metrics-custom-allowlist
      namespace: open-cluster-management-observability
  2: |
    apiVersion: v1
    data:
      uwl_metrics_list.yaml: |
        names:
          - probe_success
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: observability-metrics-custom-allowlist
      namespace: apc-blackbox-exporter
  3: |
    apiVersion: v1
    data:
      uwl_metrics_list.yaml: |
        names:
          - vault_core_active
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: observability-metrics-custom-allowlist
      namespace: apc-vault
