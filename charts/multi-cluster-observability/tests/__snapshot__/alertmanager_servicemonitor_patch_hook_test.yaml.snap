renders patch hook resources for hub clusters:
  1: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      annotations:
        helm.sh/hook: post-install,post-upgrade
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded
        helm.sh/hook-weight: "10"
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: multi-cluster-observability-multi-cluster-observability-alertmanager-servicemonitor-patch
      namespace: open-cluster-management-observability
  2: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: Role
    metadata:
      annotations:
        helm.sh/hook: post-install,post-upgrade
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded
        helm.sh/hook-weight: "10"
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: multi-cluster-observability-multi-cluster-observability-alertmanager-servicemonitor-patch
      namespace: open-cluster-management-observability
    rules:
      - apiGroups:
          - monitoring.coreos.com
        resourceNames:
          - alertmanager
        resources:
          - servicemonitors
        verbs:
          - get
          - patch
  3: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: RoleBinding
    metadata:
      annotations:
        helm.sh/hook: post-install,post-upgrade
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded
        helm.sh/hook-weight: "10"
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: multi-cluster-observability-multi-cluster-observability-alertmanager-servicemonitor-patch
      namespace: open-cluster-management-observability
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: Role
      name: multi-cluster-observability-multi-cluster-observability-alertmanager-servicemonitor-patch
    subjects:
      - kind: ServiceAccount
        name: multi-cluster-observability-multi-cluster-observability-alertmanager-servicemonitor-patch
        namespace: open-cluster-management-observability
  4: |
    apiVersion: batch/v1
    kind: Job
    metadata:
      annotations:
        helm.sh/hook: post-install,post-upgrade
        helm.sh/hook-delete-policy: before-hook-creation,hook-succeeded
        helm.sh/hook-weight: "20"
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: multi-cluster-observability-multi-cluster-observability-alertmanager-servicemonitor-patch
      namespace: open-cluster-management-observability
    spec:
      backoffLimit: 3
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: multi-cluster-observability
            app.kubernetes.io/name: multi-cluster-observability
        spec:
          containers:
            - command:
                - /bin/bash
                - -ec
                - |
                  target="/var/run/secrets/kubernetes.io/serviceaccount/token"
                  for i in $(seq 1 60); do
                    if oc get servicemonitor alertmanager -n open-cluster-management-observability >/dev/null 2>&1; then
                      break
                    fi
                    sleep 5
                  done

                  current="$(oc get servicemonitor alertmanager -n open-cluster-management-observability -o jsonpath='{.spec.endpoints[0].bearerTokenFile}')"
                  if [ "$current" = "$target" ]; then
                    exit 0
                  fi

                  op="add"
                  if [ -n "$current" ]; then
                    op="replace"
                  fi

                  oc patch servicemonitor alertmanager \
                    -n open-cluster-management-observability \
                    --type='json' \
                    -p="[{\"op\":\"${op}\",\"path\":\"/spec/endpoints/0/bearerTokenFile\",\"value\":\"${target}\"}]"
              image: registry.redhat.io/openshift4/ose-cli:v4.15
              imagePullPolicy: IfNotPresent
              name: patch-alertmanager-servicemonitor
          restartPolicy: OnFailure
          serviceAccountName: multi-cluster-observability-multi-cluster-observability-alertmanager-servicemonitor-patch
