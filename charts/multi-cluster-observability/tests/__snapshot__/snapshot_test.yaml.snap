ieldsByName", "options": {"include": {"names": ["clusterName", "namespace"]}}}, {"id": "groupBy", "options": {"fields": {"clusterName": {"aggregations": [], "operation": "groupby"}, "namespace": {"aggregations": [], "operation": "groupby"}}}}], "type": "table"}], "schemaVersion": 39, "tags": ["APC", "Projects"], "templating": {"list": []}, "time": {"from": "now-1M/M", "to": "now-1M/M"}, "timepicker": {}, "timezone": "browser", "title": "Application Projects running in APC", "version": 2, "weekStart": ""}
    kind: ConfigMap
    metadata:
      annotations:
        observability.open-cluster-management.io/dashboard-folder: Custom
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        grafana-custom-dashboard: "true"
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: application-projects-running-in-apc
      namespace: open-cluster-management-observability
  24: |
    apiVersion: observability.open-cluster-management.io/v1beta2
    kind: MultiClusterObservability
    metadata:
      annotations:
        mco-disable-alerting: "true"
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: observability
    spec:
      advanced:
        retentionConfig:
          blockDuration: 2h
          deleteDelay: 48h
          retentionInLocal: 24h
          retentionResolution1h: 90d
          retentionResolution5m: 45d
          retentionResolutionRaw: 35d
      observabilityAddonSpec:
        interval: 30
      storageConfig:
        metricObjectStorage:
          key: thanos.yaml
          name: thanos-object-storage
          tlsSecretMountPath: /etc/ssl/certs/thanos
          tlsSecretName: thanos-tls-ca
  25: |
    apiVersion: objectbucket.io/v1alpha1
    kind: ObjectBucketClaim
    metadata:
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: acm-thanos-rgw
      namespace: open-cluster-management-observability
    spec:
      generateBucketName: acm-thanos-rgw
      storageClassName: ocs-storagecluster-ceph-rgw
  26: |
    apiVersion: kyverno.io/v1
    kind: Policy
    metadata:
      annotations:
        policies.kyverno.io/category: ODF
        policies.kyverno.io/minversion: 1.13.0
        policies.kyverno.io/subject: Thanos Object Storage
        policies.kyverno.io/title: Generate Thanos Object Storage Secret
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: generate-thanos-object-storage-secret
      namespace: open-cluster-management-observability
    spec:
      background: true
      rules:
        - context:
            - apiCall:
                default: '{}'
                urlPath: /api/v1/namespaces/{{request.object.metadata.namespace}}/secrets/{{request.object.metadata.name}}
              name: obcsecret
            - apiCall:
                default: '{}'
                urlPath: /api/v1/namespaces/{{request.object.metadata.namespace}}/configmaps/{{request.object.metadata.name}}
              name: obcconfigmap
          generate:
            apiVersion: v1
            data:
              metadata:
                labels:
                  app.kubernetes.io/instance: multi-cluster-observability
                  app.kubernetes.io/managed-by: Helm
                  app.kubernetes.io/name: multi-cluster-observability
                  app.kubernetes.io/part-of: multi-cluster-observability
                  helm.sh/chart: multi-cluster-observability-1.0.0
              stringData:
                thanos.yaml: |
                  type: s3
                  config:
                    bucket: {{ obcconfigmap.data.BUCKET_NAME }}
                    endpoint: {{ obcconfigmap.data.BUCKET_HOST }}:{{ obcconfigmap.data.BUCKET_PORT }}
                    insecure: false
                    access_key: "{{ base64_decode(obcsecret.data.AWS_ACCESS_KEY_ID || '') }}"
                    secret_key: "{{ base64_decode(obcsecret.data.AWS_SECRET_ACCESS_KEY || '') }}"
                    http_config:
                      tls_config:
                        insecure_skip_verify: false
                        ca_file: /etc/ssl/certs/thanos/service-ca.crt
              type: Opaque
            generateExisting: true
            kind: Secret
            name: thanos-object-storage
            namespace: open-cluster-management-observability
            orphanDownstreamOnPolicyDelete: true
            synchronize: true
          match:
            all:
              - resources:
                  kinds:
                    - ObjectBucketClaim
          name: thanos-object-storage
          preconditions:
            all:
              - key: '{{ obcsecret }} | length(keys(@))'
                operator: NotEquals
                value: "0"
              - key: '{{ obcconfigmap }} | length(keys(@))'
                operator: NotEquals
                value: "0"
              - key: '{{ request.object.metadata.deletionTimestamp || '''' }}'
                operator: Equals
                value: ""
          skipBackgroundRequests: true
