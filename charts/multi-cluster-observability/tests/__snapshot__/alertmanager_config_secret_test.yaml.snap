renders the hub alertmanager config external secret:
  1: |
    apiVersion: external-secrets.io/v1beta1
    kind: ExternalSecret
    metadata:
      labels:
        app.kubernetes.io/instance: multi-cluster-observability
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: multi-cluster-observability
        app.kubernetes.io/part-of: multi-cluster-observability
        helm.sh/chart: multi-cluster-observability-1.0.0
      name: alertmanager-config
      namespace: open-cluster-management-observability
    spec:
      data:
        - remoteRef:
            key: customers/socpoist/msteams
            property: sp-apc-alerts-!hub-url
          secretKey: webhookUrl
      refreshInterval: 15m
      secretStoreRef:
        kind: ClusterSecretStore
        name: vault-hub-secret-store
      target:
        creationPolicy: Owner
        name: alertmanager-config
        template:
          data:
            alertmanager.yaml: |
              "global":
                "resolve_timeout": "5m"
              "receivers":
              - name: "null"
              - name: "teams_aspecta"
                msteams_configs:
                  - send_resolved: true
                    webhook_url: "{{ .webhookUrl }}"
              "route":
                "group_by": ['alertname', 'cluster', 'service']
                "group_wait": "30s"
                "group_interval": "5m"
                "receiver": "teams_aspecta"
                "repeat_interval": "12h"
                "routes":
                - "matchers":
                  - "severity = warning"
                  "receiver": "teams_aspecta"
                - "matchers":
                  - "severity = critical"
                  "receiver": "teams_aspecta"
                - "receiver": "null"
                  "matchers":
                  - alertname = Watchdog
                - "receiver": "null"
                  "matchers":
                  - severity =~ "info|none"
          metadata:
            labels:
              app.kubernetes.io/instance: multi-cluster-observability
              app.kubernetes.io/managed-by: Helm
              app.kubernetes.io/name: multi-cluster-observability
              app.kubernetes.io/part-of: multi-cluster-observability
              helm.sh/chart: multi-cluster-observability-1.0.0
          type: Opaque
