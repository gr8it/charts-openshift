manifests should match snapshot:
  1: |
    raw: |
      1. Get the application URL by running these commands:
        export POD_NAME=$(kubectl get pods --namespace prometheus-pushgateway -l "app.kubernetes.io/name=prometheus-pushgateway,app.kubernetes.io/instance=prometheus-pushgateway" -o jsonpath="{.items[0].metadata.name}")
        kubectl port-forward $POD_NAME 9091
        echo "Visit http://127.0.0.1:9091 to use your application"
  2: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.11.0
        helm.sh/chart: prometheus-pushgateway-3.0.0
      name: prometheus-pushgateway
      namespace: prometheus-pushgateway
    spec:
      replicas: 2
      selector:
        matchLabels:
          app.kubernetes.io/instance: prometheus-pushgateway
          app.kubernetes.io/name: prometheus-pushgateway
      strategy:
        type: Recreate
      template:
        metadata:
          labels:
            app.kubernetes.io/instance: prometheus-pushgateway
            app.kubernetes.io/managed-by: Helm
            app.kubernetes.io/name: prometheus-pushgateway
            app.kubernetes.io/version: v1.11.0
            helm.sh/chart: prometheus-pushgateway-3.0.0
        spec:
          automountServiceAccountToken: true
          containers:
            - args:
                - --https-address=:9092
                - --provider=openshift
                - --openshift-service-account=pushgw-sa
                - --openshift-delegate-urls={"/":{"group":"monitoring.coreos.com","resource":"prometheuses","verb":"get"}}
                - --upstream=http://localhost:9091
                - --tls-cert=/etc/tls/private/tls.crt
                - --tls-key=/etc/tls/private/tls.key
                - --cookie-secret-file=/etc/proxy/secrets/cookie-secret
              image: registry.redhat.io/openshift4/ose-oauth-proxy:v4.12.0
              imagePullPolicy: Always
              name: oauth-proxy
              ports:
                - containerPort: 9092
                  name: public
              volumeMounts:
                - mountPath: /etc/tls/private
                  name: prometheus-pushgateway-tls
                - mountPath: /etc/proxy/secrets
                  name: pushgateway-cookie-secret
                  readOnly: true
            - args:
                - --web.enable-admin-api
              image: quay.io/prometheus/pushgateway:v1.10.0
              imagePullPolicy: Always
              livenessProbe:
                httpGet:
                  path: /-/healthy
                  port: 9091
                initialDelaySeconds: 10
                timeoutSeconds: 10
              name: pushgateway
              ports:
                - containerPort: 9091
                  name: metrics
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /-/ready
                  port: 9091
                initialDelaySeconds: 10
                timeoutSeconds: 10
              volumeMounts:
                - mountPath: /data
                  name: storage-volume
                  subPath: ""
          securityContext:
            fsGroup: 65534
            runAsNonRoot: true
            runAsUser: 65534
          serviceAccountName: pushgw-sa
          volumes:
            - name: storage-volume
              persistentVolumeClaim:
                claimName: prometheus-pushgateway
            - name: prometheus-pushgateway-tls
              secret:
                secretName: prometheus-pushgateway-tls
            - name: pushgateway-cookie-secret
              secret:
                secretName: pushgateway-oauth-cookie-secret
  3: |
    apiVersion: v1
    kind: PersistentVolumeClaim
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.11.0
        helm.sh/chart: prometheus-pushgateway-3.0.0
      name: prometheus-pushgateway
      namespace: prometheus-pushgateway
    spec:
      accessModes:
        - ReadWriteOnce
      resources:
        requests:
          storage: 2Gi
  4: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.11.0
        helm.sh/chart: prometheus-pushgateway-3.0.0
      name: prometheus-pushgateway
      namespace: prometheus-pushgateway
    spec:
      ports:
        - name: http
          port: 9091
          protocol: TCP
          targetPort: 9091
      selector:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/name: prometheus-pushgateway
      type: ClusterIP
  5: |
    apiVersion: monitoring.coreos.com/v1
    kind: ServiceMonitor
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.11.0
        helm.sh/chart: prometheus-pushgateway-3.0.0
      name: prometheus-pushgateway
      namespace: openshift-monitoring
    spec:
      endpoints:
        - honorLabels: true
          path: /metrics
          port: http
      namespaceSelector:
        matchNames:
          - prometheus-pushgateway
      selector:
        matchLabels:
          app.kubernetes.io/instance: prometheus-pushgateway
          app.kubernetes.io/name: prometheus-pushgateway
  6: |
    raw: |
      Pushgateway deployed in prometheus-pushgateway.

      Route:  oc get route prometheus-pushgateway -n prometheus-pushgateway
      Secret: oc get externalsecret prometheus-pushgateway-oauth-cookie -n prometheus-pushgateway
  7: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: service-sa-push-metrics
    rules:
      - apiGroups:
          - monitoring.coreos.com
        resources:
          - prometheuses
          - servicemonitors
        verbs:
          - get
          - list
  8: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: tokenreview-access
    rules:
      - apiGroups:
          - authentication.k8s.io
        resources:
          - tokenreviews
        verbs:
          - create
      - apiGroups:
          - authorization.k8s.io
        resources:
          - subjectaccessreviews
        verbs:
          - create
  9: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRoleBinding
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: pushgw-sa-tokenreview-binding
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: ClusterRole
      name: tokenreview-access
    subjects:
      - kind: ServiceAccount
        name: pushgw-sa
        namespace: prometheus-pushgateway
  10: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: Role
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: pushgw-sa-prometheus-access
      namespace: prometheus-pushgateway
    rules:
      - apiGroups:
          - monitoring.coreos.com
        resources:
          - prometheuses
        verbs:
          - get
  11: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: RoleBinding
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: pushgw-sa-binding
      namespace: prometheus-pushgateway
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: Role
      name: pushgw-sa-prometheus-access
    subjects:
      - kind: ServiceAccount
        name: pushgw-sa
        namespace: prometheus-pushgateway
  12: |
    apiVersion: route.openshift.io/v1
    kind: Route
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: prometheus-pushgateway
      namespace: prometheus-pushgateway
    spec:
      tls:
        termination: Reencrypt
      to:
        kind: Service
        name: pushgateway-oauth-proxy
  13: |
    apiVersion: generators.external-secrets.io/v1alpha1
    kind: Password
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: prometheus-pushgateway-oauth-cookie
      namespace: prometheus-pushgateway
    spec:
      allowRepeat: true
      digits: 6
      length: 32
      noUpper: false
      symbols: 0
  14: |
    apiVersion: external-secrets.io/v1beta1
    kind: ExternalSecret
    metadata:
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: prometheus-pushgateway-oauth-cookie
      namespace: prometheus-pushgateway
    spec:
      dataFrom:
        - sourceRef:
            generatorRef:
              apiVersion: generators.external-secrets.io/v1alpha1
              kind: Password
              name: prometheus-pushgateway-oauth-cookie
      refreshInterval: "0"
      target:
        creationPolicy: Owner
        name: pushgateway-oauth-cookie-secret
        template:
          data:
            cookie-secret: '{{ . }}'
          metadata:
            labels:
              app.kubernetes.io/instance: prometheus-pushgateway
              app.kubernetes.io/managed-by: Helm
              app.kubernetes.io/name: prometheus-pushgateway
              app.kubernetes.io/version: v1.10.0
              helm.sh/chart: pushgateway-helm-1.0.0
  15: |
    apiVersion: v1
    kind: Service
    metadata:
      annotations:
        service.alpha.openshift.io/serving-cert-secret-name: prometheus-pushgateway-tls
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: pushgateway-oauth-proxy
      namespace: prometheus-pushgateway
    spec:
      ports:
        - name: https
          port: 9092
          targetPort: 9092
      selector:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/name: prometheus-pushgateway
  16: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      annotations:
        serviceaccounts.openshift.io/oauth-redirectreference.primary: '{"kind":"OAuthRedirectReference","apiVersion":"v1","reference":{"kind":"Route","name":"prometheus-pushgateway"}}'
      labels:
        app.kubernetes.io/instance: prometheus-pushgateway
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: prometheus-pushgateway
        app.kubernetes.io/version: v1.10.0
        helm.sh/chart: pushgateway-helm-1.0.0
      name: pushgw-sa
      namespace: prometheus-pushgateway
