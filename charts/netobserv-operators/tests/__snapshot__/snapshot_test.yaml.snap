manifests should match snapshot:
  1: |
    apiVersion: policy.open-cluster-management.io/v1beta1
    kind: OperatorPolicy
    metadata:
      annotations: {}
      labels:
        app.kubernetes.io/instance: netobserv-operators
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: netobserv-operatorpolicy
        app.kubernetes.io/version: v1beta1
        helm.sh/chart: netobserv-operatorpolicy-1.3.0
      name: netobserv-operators-netobserv-operatorpolicy
      namespace: open-cluster-management-policies
    spec:
      complianceConfig:
        catalogSourceUnhealthy: Compliant
        deploymentsUnavailable: NonCompliant
        upgradesAvailable: Compliant
      complianceType: musthave
      operatorGroup:
        name: openshift-netobserv-operator
        namespace: openshift-netobserv-operator
        targetNamespaces:
          - openshift-netobserv-operator
      remediationAction: enforce
      removalBehavior:
        clusterServiceVersions: Delete
        customResourceDefinitions: Keep
        operatorGroups: DeleteIfUnused
        subscriptions: Delete
      severity: medium
      subscription:
        channel: stable
        name: netobserv-operator
        namespace: openshift-netobserv-operator
        source: redhat-operators
        sourceNamespace: openshift-marketplace
        startingCSV: netobserv-operator.v1.7.0
      upgradeApproval: None
      versions:
