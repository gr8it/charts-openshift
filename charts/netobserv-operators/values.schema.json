{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "netobserv-operatorpolicy": {
      "type": "object",
      "required": ["subscription", "operatorGroup", "versions"],
      "properties": {
        "enabled": { "type": "boolean" },
        "subscription": {
          "type": "object",
          "required": ["channel", "name", "namespace", "source", "sourceNamespace", "startingCSV"],
          "properties": {
            "channel": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "minLength": 1 },
            "sourceNamespace": { "type": "string", "minLength": 1 },
            "startingCSV": { "type": "string", "minLength": 1 }
          }
        },
        "operatorGroup": {
          "type": "object",
          "required": ["name", "namespace"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 },
            "targetNamespaces": { "type": "array", "items": { "type": "string" } }
          }
        },
        "upgradeApproval": { "type": "string", "enum": ["None", "Automatic"] },
        "versions": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
      }
    }
  }
}
