  7: |
    apiVersion: vault.vault.upbound.io/v1alpha1
    kind: Policy
    metadata:
      annotations:
        crossplane.io/external-name: admin
      labels:
        app.kubernetes.io/instance: vault-config
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: vault-config
        helm.sh/chart: vault-config-1.0.0
      name: admin-policy
    spec:
      forProvider:
        name: admin
        policy: |
          path "*" {
            capabilities = ["create", "read", "update", "delete", "list", "sudo"]
          }
      providerConfigRef:
        name: null
  8: |
    apiVersion: vault.vault.upbound.io/v1alpha1
    kind: Policy
    metadata:
      annotations:
        crossplane.io/external-name: pki-spoke-cluster-issuer
      labels:
        app.kubernetes.io/instance: vault-config
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: vault-config
        helm.sh/chart: vault-config-1.0.0
      name: pki-spoke-cluster-issuer-policy
    spec:
      forProvider:
        name: pki-spoke-cluster-issuer
        policy: |
          path "pki/sign/*" {
            capabilities = ["create", "update"]
          }
          path "pki/issuer/*" {
            capabilities = ["read"]
          }
          path "pki/roles/*" {
            capabilities = ["list"]
          }
          path "pki_int/sign/*" {
            capabilities = ["create", "update"]
          }
          path "pki/issue/apc.socpoist.sk" {
            capabilities = ["create", "update"]
          }
      providerConfigRef:
        name: null
  9: |
    apiVersion: vault.vault.upbound.io/v1alpha1
    kind: Policy
    metadata:
      annotations:
        crossplane.io/external-name: snapshot
      labels:
        app.kubernetes.io/instance: vault-config
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: vault-config
        helm.sh/chart: vault-config-1.0.0
      name: snapshot-policy
    spec:
      forProvider:
        name: snapshot
        policy: |
          path "sys/storage/raft/snapshot" {
            capabilities = ["read"]
          }
      providerConfigRef:
        name: null
