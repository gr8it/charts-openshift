manifests should match snapshot:
  1: |
    apiVersion: vault.vault.upbound.io/v1alpha1
    kind: Audit
    metadata:
      annotations:
        crossplane.io/external-name: file
      labels:
        app.kubernetes.io/instance: vault-config
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: vault-config
        helm.sh/chart: vault-config-1.0.0
      name: audit
    spec:
      deletionPolicy: Orphan
      forProvider:
        options:
          file_path: stdout
        type: file
      managementPolicy:
        - Create
        - Update
        - Observe
        - LateInitialize
      providerConfigRef:
        name: null
