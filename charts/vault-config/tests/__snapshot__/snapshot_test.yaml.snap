  8: |
    apiVersion: vault.vault.upbound.io/v1alpha1
    kind: Policy
    metadata:
      annotations:
        crossplane.io/external-name: admin
      labels:
        app.kubernetes.io/instance: vault-config
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: vault-config
        helm.sh/chart: vault-config-1.0.0
      name: admin-policy
    spec:
      deletionPolicy: Orphan
      forProvider:
        name: admin
        policy: |
          path "*" {
            capabilities = ["create", "read", "update", "delete", "list", "sudo"]
          }
      managementPolicy:
        - Create
        - Update
        - Observe
        - LateInitialize
      providerConfigRef:
        name: null
  9: |
    apiVersion: vault.vault.upbound.io/v1alpha1
    kind: Policy
    metadata:
      annotations:
        crossplane.io/external-name: pki-spoke-cluster-issuer
      labels:
        app.kubernetes.io/instance: vault-config
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: vault-config
        helm.sh/chart: vault-config-1.0.0
      name: pki-spoke-cluster-issuer-policy
    spec:
      deletionPolicy: Orphan
      forProvider:
        name: pki-spoke-cluster-issuer
        policy: |
          path "pki/sign/*" {
            capabilities = ["create", "update"]
          }
          path "pki/issuer/*" {
            capabilities = ["read"]
          }
          path "pki/roles/*" {
            capabilities = ["list"]
          }
          path "pki_int/sign/*" {
            capabilities = ["create", "update"]
          }
          path "pki/issue/apc.socpoist.sk" {
            capabilities = ["create", "update"]
          }
      managementPolicy:
        - Create
        - Update
        - Observe
        - LateInitialize
      providerConfigRef:
        name: null
  10: |
    apiVersion: vault.vault.upbound.io/v1alpha1
    kind: Policy
    metadata:
      annotations:
        crossplane.io/external-name: snapshot
      labels:
        app.kubernetes.io/instance: vault-config
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: vault-config
        helm.sh/chart: vault-config-1.0.0
      name: snapshot-policy
    spec:
      deletionPolicy: Orphan
      forProvider:
        name: snapshot
        policy: |
          path "sys/storage/raft/snapshot" {
            capabilities = ["read"]
          }
      managementPolicy:
        - Create
        - Update
        - Observe
        - LateInitialize
      providerConfigRef:
        name: null
  11: |
    apiVersion: pki.vault.upbound.io/v1alpha1
    kind: SecretBackendRole
    metadata:
      annotations:
        crossplane.io/external-name: pki/roles/.
      labels:
        app.kubernetes.io/instance: vault-config
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: vault-config
        helm.sh/chart: vault-config-1.0.0
      name: .
    spec:
      deletionPolicy: Orphan
      forProvider:
        allowBareDomains: true
        allowLocalhost: false
        allowSubdomains: true
        allowedDomains:
          - svc
          - cluster.local
          - .
          - service..
        backend: pki
        issuerRef: default
        maxTtl: 365d
        name: .
        ttl: 365d
      managementPolicy:
        - Create
        - Update
        - Observe
        - LateInitialize
      providerConfigRef:
        name: null
