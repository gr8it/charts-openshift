{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "objectBucketClaim": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "storageClassName": { "type": "string", "minLength": 1 },
        "bucketName": { "type": ["string", "null"] }
      }
    },
    "lokistack": {
      "type": "object",
      "required": ["size"],
      "properties": {
        "size": {
          "type": "string",
          "enum": ["1x.demo", "1x.extra-small", "1x.pico", "1x.small", "1x.medium"]
        },
        "storage": {
          "type": "object",
          "properties": {
            "schemas": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["effectiveDate", "version"],
                "properties": {
                  "effectiveDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                  "version": { "type": "string", "enum": ["v11", "v12", "v13"] }
                }
              }
            }
          }
        },
        "storageClassName": { "type": "string", "minLength": 1 },
        "replication": {
          "type": "object",
          "properties": {
            "factor": { "type": "integer", "minimum": 1 },
            "zones": { "type": "array" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "global": {
              "type": "object",
              "properties": {
                "ingestion": {
                  "type": "object",
                  "properties": {
                    "ingestionRate": { "type": "integer" },
                    "ingestionBurstSize": { "type": "integer" },
                    "perStreamRateLimit": { "type": "integer" },
                    "perStreamRateLimitBurst": { "type": "integer" }
                  }
                },
                "queries": {
                  "type": "object",
                  "properties": {
                    "queryTimeout": { "type": "string" }
                  }
                }
              }
            },
            "retention": {
              "type": "object",
              "properties": {
                "days": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "externalSecret": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "refreshInterval": { "type": "string" }
      }
    },
    "flowCollector": {
      "type": "object",
      "properties": {
        "agent": {
          "type": "object",
          "properties": {
            "ebpf": {
              "type": "object",
              "properties": {
                "sampling": { "type": "integer", "minimum": 1 },
                "resources": { "type": "object" }
              }
            }
          }
        },
        "processor": {
          "type": "object",
          "properties": {
            "resources": { "type": "object" }
          }
        }
      }
    },
    "uiplugin": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
