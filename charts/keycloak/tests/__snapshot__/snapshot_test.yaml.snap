  2: |
    apiVersion: openidclient.keycloak.m.crossplane.io/v1alpha1
    kind: Client
    metadata:
      labels:
        app.kubernetes.io/instance: keycloak
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: keycloak
        app.kubernetes.io/version: v26.0
        helm.sh/chart: keycloak-1.6.0
      name: isas
      namespace: apc-keycloak
    spec:
      forProvider:
        accessType: CONFIDENTIAL
        clientId: isas
        description: ISAS client for Keycloak
        directAccessGrantsEnabled: false
        frontchannelLogoutEnabled: true
        fullScopeAllowed: false
        implicitFlowEnabled: false
        name: ISAS
        pkceCodeChallengeMethod: S256
        realmId: Internal
        serviceAccountsEnabled: true
        standardFlowEnabled: false
        useRefreshTokens: true
      providerConfigRef:
        kind: ClusterProviderConfig
        name: keycloak-provider-config
  3: |
    apiVersion: openidclient.keycloak.m.crossplane.io/v1alpha1
    kind: Client
    metadata:
      labels:
        app.kubernetes.io/instance: keycloak
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: keycloak
        app.kubernetes.io/version: v26.0
        helm.sh/chart: keycloak-1.6.0
      name: sf
      namespace: apc-keycloak
    spec:
      forProvider:
        accessType: CONFIDENTIAL
        clientId: sf
        description: Standard Flow client for Keycloak with default webOrigins applied = "+"
        directAccessGrantsEnabled: false
        frontchannelLogoutEnabled: true
        fullScopeAllowed: false
        implicitFlowEnabled: false
        name: SF
        pkceCodeChallengeMethod: S256
        realmId: Internal
        serviceAccountsEnabled: false
        standardFlowEnabled: true
        useRefreshTokens: true
        validRedirectUris:
          - https://sf.app.example.com/*
        webOrigins:
          - +
      providerConfigRef:
        kind: ClusterProviderConfig
        name: keycloak-provider-config
  4: |
    apiVersion: openidclient.keycloak.m.crossplane.io/v1alpha1
    kind: Client
    metadata:
      labels:
        app.kubernetes.io/instance: keycloak
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: keycloak
        app.kubernetes.io/version: v26.0
        helm.sh/chart: keycloak-1.6.0
      name: sf2
      namespace: apc-keycloak
    spec:
      forProvider:
        accessType: PUBLIC
        clientId: sf2
        description: Standard Flow client for Keycloak with "*" webOrigins
        directAccessGrantsEnabled: false
        frontchannelLogoutEnabled: true
        fullScopeAllowed: false
        implicitFlowEnabled: false
        name: SF
        pkceCodeChallengeMethod: S256
        realmId: Internal
        serviceAccountsEnabled: false
        standardFlowEnabled: true
        useRefreshTokens: true
        validRedirectUris:
          - /my/relative/path/*
        webOrigins:
          - '*'
      providerConfigRef:
        kind: ClusterProviderConfig
        name: keycloak-provider-config
  5: |
    apiVersion: postgresql.cnpg.io/v1
    kind: ScheduledBackup
    metadata:
      labels:
        app.kubernetes.io/instance: keycloak
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: keycloak
        app.kubernetes.io/version: v26.0
        helm.sh/chart: keycloak-1.6.0
      name: keycloak-backup-db
      namespace: apc-keycloak
    spec:
      backupOwnerReference: none
      cluster:
        name: keycloak-db
      immediate: true
      method: barmanObjectStore
      schedule: 0 0 1 * * 0
      suspend: false
  6: |
    apiVersion: postgresql.cnpg.io/v1
    kind: Cluster
    metadata:
      labels:
        app: keycloak
        app.kubernetes.io/instance: keycloak
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: keycloak
        app.kubernetes.io/version: v26.0
        helm.sh/chart: keycloak-1.6.0
      name: keycloak-db
      namespace: apc-keycloak
    spec:
      affinity:
        podAntiAffinityType: preferred
      backup:
        barmanObjectStore:
          destinationPath: s3://keycloak-backup
          endpointURL: http://s3.openshift-storage.svc
          s3Credentials:
            accessKeyId:
              key: access_key_id
              name: keycloak-backup-allinfo
            secretAccessKey:
              key: access_key_secret
              name: keycloak-backup-allinfo
          wal:
            compression: bzip2
            maxParallel: 4
        retentionPolicy: 2w
        target: prefer-standby
      bootstrap:
        initdb:
          dataChecksums: true
          database: keycloak
          encoding: UTF8
          localeCType: en_US.utf8
          localeCollate: en_US.utf8
          owner: keycloak
          secret:
            name: keycloak-db-auth
          walSegmentSize: 1
      imageName: ghcr.io/cloudnative-pg/postgresql:16.4
      instances: 3
      maxSyncReplicas: 2
      minSyncReplicas: 1
      monitoring:
        enablePodMonitor: true
      postgresql:
        parameters:
          max_slot_wal_keep_size: 500MB
          shared_buffers: 256MB
          wal_keep_size: "200"
        syncReplicaElectionConstraint:
          enabled: false
          nodeLabelsAntiAffinity:
            - topology.kubernetes.io/zone
      primaryUpdateMethod: switchover
      primaryUpdateStrategy: unsupervised
      replicationSlots:
        updateInterval: 30
      resources:
        limits:
          cpu: "1"
          memory: 500Mi
        requests:
          cpu: 100m
          memory: 500Mi
      storage:
        size: 1Gi
      walStorage:
        size: 1Gi
  7: |
    apiVersion: v1
    kind: ConfigMap
    metadata:
      annotations:
        request-egressip: "2"
      labels:
        app.kubernetes.io/instance: keycloak
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: keycloak
        app.kubernetes.io/version: v26.0
        helm.sh/chart: keycloak-1.6.0
      name: keycloak-egressip
      namespace: apc-keycloak
  8: |
    apiVersion: external-secrets.io/v1beta1
    kind: ExternalSecret
    metadata:
      labels:
        app.kubernetes.io/instance: keycloak
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: keycloak
        app.kubernetes.io/version: v26.0
        helm.sh/chart: keycloak-1.6.0
      name: idp-internal-keycloak-oidc-credentials
      namespace: apc-keycloak
    spec:
      data:
        - remoteRef:
            key: apc-platform/l/keycloak/Internal/identity-providers/keycloak-oidc/credentials
            property: client-id
          secretKey: client-id
        - remoteRef:
            key: apc-platform/l/keycloak/Internal/identity-providers/keycloak-oidc/credentials
            property: client-secret
          secretKey: client-secret
      secretStoreRef:
        kind: ClusterSecretStore
        name: vault-hub-secret-store
      target:
        creationPolicy: Owner
        name: idp-internal-keycloak-oidc-credentials
        template:
          data:
            client-id: '{{ .client-id }}'
            client-secret: '{{ .client-secret }}'
