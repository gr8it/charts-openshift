  8: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: RoleBinding
    metadata:
      labels:
        app.kubernetes.io/instance: apps-kafka-bridge
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: apps-kafka-bridge
        app.kubernetes.io/version: 0.46.1
        helm.sh/chart: apps-kafka-bridge-1.1.0
      name: apps-kafka-bridge-account-access
      namespace: NAMESPACE
    roleRef:
      apiGroup: rbac.authorization.k8s.io
      kind: Role
      name: apps-kafka-bridge-account-access
    subjects:
      - kind: ServiceAccount
        name: apps-kafka-bridge-account-access
        namespace: ekp
  9: |
    apiVersion: route.openshift.io/v1
    kind: Route
    metadata:
      labels:
        app.kubernetes.io/instance: apps-kafka-bridge
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: apps-kafka-bridge
        app.kubernetes.io/version: 0.46.1
        helm.sh/chart: apps-kafka-bridge-1.1.0
      name: apps-kafka-bridge
      namespace: NAMESPACE
    spec:
      host: apps-kafka-bridge.apps.test.example.com
      port:
        targetPort: http
      tls:
        termination: edge
      to:
        kind: Service
        name: apps-kafka-bridge-oauth-proxy
        weight: 100
      wildcardPolicy: None
  10: |
    apiVersion: v1
    kind: Secret
    metadata:
      labels:
        app.kubernetes.io/instance: apps-kafka-bridge
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: apps-kafka-bridge
        app.kubernetes.io/version: 0.46.1
        helm.sh/chart: apps-kafka-bridge-1.1.0
      name: apps-kafka-bridge-account-access
      namespace: NAMESPACE
    stringData:
      description: Fake Secret to give service account access to a given service behind openshift-oauth-proxy.
  11: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app.kubernetes.io/instance: apps-kafka-bridge
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: apps-kafka-bridge
        app.kubernetes.io/version: 0.46.1
        helm.sh/chart: apps-kafka-bridge-1.1.0
      name: apps-kafka-bridge-oauth-proxy
      namespace: NAMESPACE
    spec:
      ports:
        - name: http
          port: 8080
          protocol: TCP
          targetPort: 8080
      selector:
        app: apps-kafka-bridge-oauth-proxy
      type: ClusterIP
  12: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      labels:
        app.kubernetes.io/instance: apps-kafka-bridge
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: apps-kafka-bridge
        app.kubernetes.io/version: 0.46.1
        helm.sh/chart: apps-kafka-bridge-1.1.0
      name: apps-kafka-bridge-account-access
      namespace: ekp
  13: |
    apiVersion: v1
    kind: ServiceAccount
    metadata:
      annotations:
        serviceaccounts.openshift.io/oauth-redirectreference.primary: '{"kind":"OAuthRedirectReference","apiVersion":"v1","reference":{"kind":"Route","name":"apps-kafka-bridge"}}'
      labels:
        app.kubernetes.io/instance: apps-kafka-bridge
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: apps-kafka-bridge
        app.kubernetes.io/version: 0.46.1
        helm.sh/chart: apps-kafka-bridge-1.1.0
      name: apps-kafka-bridge-oauth-proxy
      namespace: NAMESPACE
  14: |
    apiVersion: monitoring.coreos.com/v1
    kind: ServiceMonitor
    metadata:
      labels:
        app.kubernetes.io/instance: apps-kafka-bridge
        app.kubernetes.io/managed-by: ArgoCD
        app.kubernetes.io/name: apps-kafka-bridge
        app.kubernetes.io/version: 0.46.1
        helm.sh/chart: apps-kafka-bridge-1.1.0
      name: apps-kafka-bridge
      namespace: NAMESPACE
    spec:
      endpoints:
        - interval: 30s
          path: /metrics
          port: rest-api
      selector:
        matchLabels:
          strimzi.io/cluster: apps-kafka-bridge
          strimzi.io/name: apps-kafka-bridge-bridge
