manifests should match snapshot:
  1: |
    apiVersion: flows.netobserv.io/v1beta2
    kind: FlowCollector
    metadata:
      labels:
        app.kubernetes.io/instance: netobserv-config
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: netobserv-config
        helm.sh/chart: netobserv-config-1.0.0
      name: cluster
    spec:
      agent:
        ebpf:
          resources:
            limits:
              cpu: "2"
              memory: 1Gi
            requests:
              cpu: 100m
              memory: 50Mi
          sampling: 100
        type: eBPF
      consolePlugin:
        enable: true
      deploymentModel: Direct
      loki:
        lokiStack:
          name: netobserv-config
        mode: LokiStack
      namespace: netobserv
      processor:
        resources:
          limits:
            cpu: "2"
            memory: 1Gi
          requests:
            cpu: 100m
            memory: 100Mi
  2: |
    apiVersion: loki.grafana.com/v1
    kind: LokiStack
    metadata:
      labels:
        app.kubernetes.io/instance: netobserv-config
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: netobserv-config
        helm.sh/chart: netobserv-config-1.0.0
      name: netobserv-config
      namespace: netobserv
    spec:
      hashRing:
        memberlist:
          instanceAddrType: podIP
        type: memberlist
      limits:
        global:
          ingestion:
            ingestionBurstSize: 24
            ingestionRate: 8
            perStreamRateLimit: 4
            perStreamRateLimitBurst: 17
          retention:
            days: 14
      replication:
        factor: 2
        zones:
          - maxSkew: 1
            topologyKey: topology.kubernetes.io/zone
      size: 1x.small
      storage:
        schemas:
          - effectiveDate: "2025-03-30"
            version: v13
        secret:
          name: netobserv-config-rgw-allinfo
          type: s3
        tls:
          caKey: service-ca.crt
          caName: openshift-service-ca.crt
      storageClassName: ocs-storagecluster-ceph-rbd
      tenants:
        mode: openshift-network
  3: |
    apiVersion: v1
    kind: Namespace
    metadata:
      labels:
        apc.namespace.type: platform
        app.kubernetes.io/instance: netobserv-config
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: netobserv-config
        helm.sh/chart: netobserv-config-1.0.0
        openshift.io/cluster-monitoring: "true"
      name: netobserv
  4: |
    apiVersion: networking.k8s.io/v1
    kind: NetworkPolicy
    metadata:
      labels:
        app.kubernetes.io/instance: netobserv-config
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: netobserv-config
        helm.sh/chart: netobserv-config-1.0.0
      name: apc-flowlogs-pipeline-network-policy
      namespace: netobserv
    spec:
      ingress:
        - from:
            - namespaceSelector:
                matchLabels:
                  kubernetes.io/metadata.name: netobserv-privileged
              podSelector:
                matchLabels:
                  app: netobserv-ebpf-agent
          ports:
            - port: 2055
              protocol: TCP
      podSelector:
        matchLabels:
          app: flowlogs-pipeline
      policyTypes:
        - Ingress
  5: |
    apiVersion: networking.k8s.io/v1
    kind: NetworkPolicy
    metadata:
      labels:
        app.kubernetes.io/instance: netobserv-config
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: netobserv-config
        helm.sh/chart: netobserv-config-1.0.0
      name: apc-netobserv-plugin-network-policy
      namespace: netobserv
    spec:
      ingress:
        - from:
            - namespaceSelector:
                matchLabels:
                  kubernetes.io/metadata.name: openshift-console
              podSelector:
                matchLabels:
                  app: console
                  component: ui
          ports:
            - port: 9001
              protocol: TCP
      podSelector:
        matchLabels:
          app: netobserv-plugin
      policyTypes:
        - Ingress
  6: |
    apiVersion: objectbucket.io/v1alpha1
    kind: ObjectBucketClaim
    metadata:
      labels:
        app.kubernetes.io/instance: netobserv-config
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: netobserv-config
        helm.sh/chart: netobserv-config-1.0.0
      name: netobserv-config-rgw
      namespace: netobserv
    spec:
      bucketName: apc-netobserv-config-rgw
      storageClassName: ocs-storagecluster-ceph-rgw
