          - "severity =~ warning|info"
        - equal:
          - namespace
          - alertname
          source_matchers:
          - "severity = warning"
          target_matchers:
          - "severity = info"
        receivers:
        - name: "null"
        - name: teams_aspecta
          msteams_configs:
