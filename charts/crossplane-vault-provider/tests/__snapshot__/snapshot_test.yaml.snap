manifests should match snapshot:
  1: |
    apiVersion: v1
    data:
      ca.crt: |
        -----BEGIN CERTIFICATE-----
        aaa
        -----END CERTIFICATE-----
        -----BEGIN CERTIFICATE-----
        bbb
        -----END CERTIFICATE-----
    kind: ConfigMap
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-vault-provider
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-vault-provider
        app.kubernetes.io/version: v2.2.2
        helm.sh/chart: crossplane-vault-provider-1.5.0
      name: crossplane-vault-provider-ca-certificates
      namespace: apc-crossplane-system
  2: |
    apiVersion: pkg.crossplane.io/v1beta1
    kind: DeploymentRuntimeConfig
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-vault-provider
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-vault-provider
        app.kubernetes.io/version: v2.2.2
        helm.sh/chart: crossplane-vault-provider-1.5.0
      name: crossplane-vault-provider-config
      namespace: apc-crossplane-system
    spec:
      deploymentTemplate:
        spec:
          replicas: 2
          selector: {}
          template:
            spec:
              containers:
                - name: package-runtime
                  resources:
                    limits:
                      cpu: 500m
                      memory: 300Mi
                    requests:
                      cpu: 20m
                      memory: 50Mi
                  securityContext: {}
                  volumeMounts:
                    - mountPath: /etc/ssl/certs/vault-ca.crt
                      name: custom-ca-certs
                      readOnly: true
                      subPath: ca.crt
              securityContext: {}
              topologySpreadConstraints:
                - labelSelector:
                    matchLabels:
                      pkg.crossplane.io/provider: provider-vault
                  maxSkew: 1
                  topologyKey: kubernetes.io/hostname
                  whenUnsatisfiable: ScheduleAnyway
              volumes:
                - configMap:
                    name: crossplane-vault-provider-ca-certificates
                  name: custom-ca-certs
  3: |
    apiVersion: pkg.crossplane.io/v1
    kind: Provider
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-vault-provider
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-vault-provider
        app.kubernetes.io/version: v2.2.2
        helm.sh/chart: crossplane-vault-provider-1.5.0
      name: crossplane-vault-provider
      namespace: apc-crossplane-system
    spec:
      package: xpkg.upbound.io/upbound/provider-vault:v2.2.2
      runtimeConfigRef:
        name: crossplane-vault-provider-config
