manifests should match snapshot:
  1: |
    apiVersion: networking.k8s.io/v1
    kind: NetworkPolicy
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-helm
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-helm
        app.kubernetes.io/version: 2.1.3
        helm.sh/chart: crossplane-helm-2.2.1
      name: crossplane-helm-allow-proxy
      namespace: apc-crossplane-system
    spec:
      egress:
        - to:
            - ipBlock:
                cidr: 1.2.3.4/32
            - ipBlock:
                cidr: 1.2.3.5/32
      podSelector: {}
      policyTypes:
        - Egress
  2: |
    apiVersion: monitoring.coreos.com/v1
    kind: PodMonitor
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-helm
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-helm
        app.kubernetes.io/version: 2.1.3
        helm.sh/chart: crossplane-helm-2.2.1
      name: crossplane-helm-rbac-manager
      namespace: apc-crossplane-system
    spec:
      namespaceSelector:
        matchNames:
          - apc-crossplane-system
      podMetricsEndpoints:
        - port: metrics
      selector:
        matchLabels:
          app: crossplane-rbac-manager
  3: |
    apiVersion: monitoring.coreos.com/v1
    kind: PodMonitor
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-helm
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-helm
        app.kubernetes.io/version: 2.1.3
        helm.sh/chart: crossplane-helm-2.2.1
      name: crossplane-helm
      namespace: apc-crossplane-system
    spec:
      namespaceSelector:
        matchNames:
          - apc-crossplane-system
      podMetricsEndpoints:
        - port: metrics
      selector:
        matchLabels:
          app: crossplane
  4: |
    apiVersion: monitoring.coreos.com/v1
    kind: PrometheusRule
    metadata:
      labels:
        app.kubernetes.io/instance: crossplane-helm
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: crossplane-helm
        app.kubernetes.io/version: 2.1.3
        helm.sh/chart: crossplane-helm-2.2.1
      name: crossplane-helm
      namespace: apc-crossplane-system
    spec:
      groups:
        - name: crossplane.rules
          rules:
            - alert: CrossplaneControllerDown
              annotations:
                description: Crossplane controller pod has been down for more than 10 minutes
                summary: Crossplane controller is not running
              expr: |
                absent(up{job="apc-crossplane-system/crossplane-helm"}) == 1
              for: 10m
              labels:
                severity: warning
                team: platform
                vendor: aspecta
            - alert: CrossplaneReconciliationErrors
              annotations:
                description: Crossplane controller has reconciliation errors for controller {{ $labels.controller }}
                summary: Crossplane reconciliation errors detected
              expr: |
                increase(controller_runtime_reconcile_errors_total{job="apc-crossplane-system/crossplane-helm"}[15m]) > 0
              for: 10m
              labels:
                severity: warning
                team: platform
                vendor: aspecta
            - alert: CrossplaneRBACManagerDown
              annotations:
                description: Crossplane RBAC manager pod has been down for more than 10 minutes
                summary: Crossplane RBAC manager is not running
              expr: |
                absent(up{job="apc-crossplane-system/crossplane-helm-rbac-manager"}) == 1
              for: 10m
              labels:
                severity: warning
                team: platform
                vendor: aspecta
