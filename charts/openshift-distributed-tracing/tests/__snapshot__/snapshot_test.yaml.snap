manifests should match snapshot:
  1: |
    apiVersion: kyverno.io/v2
    kind: ClusterCleanupPolicy
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: Replace=true
        policies.kyverno.io/category: gitops
        policies.kyverno.io/minversion: 1.13.0
        policies.kyverno.io/subject: TempoStack ClusterRoles
        policies.kyverno.io/title: Cleanup Tempo reader ClusterRoles for deleted or unwatched namespaces
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: apc-tempo-stack-cleanup-tempo-reader-clusterroles
    spec:
      conditions:
        all:
          - key: '{{ target.metadata.name | split(@, ''-'') | [2:] | join(''-'',@) }}'
            operator: AllNotIn
            value: '{{ appNamespaces }}'
      context:
        - apiCall:
            default: []
            jmesPath: items[?metadata.labels."apc.namespace.type" == 'application'].metadata.name
            urlPath: /api/v1/namespaces
          name: appNamespaces
      match:
        any:
          - resources:
              kinds:
                - ClusterRole
              selector:
                matchLabels:
                  generated-by: generate-reader-tempo-stack-tenant-clusterrole
          - resources:
              kinds:
                - ClusterRole
              selector:
                matchLabels:
                  generated-by: generate-writer-tempo-stack-tenant-clusterrole
      schedule: 0 12 * * *
  2: |
    apiVersion: kyverno.io/v1
    kind: ClusterPolicy
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: Replace=true
        policies.kyverno.io/category: gitops
        policies.kyverno.io/minversion: 1.13.0
        policies.kyverno.io/subject: Generate ClusterRoles for application namespaces
        policies.kyverno.io/title: Generate ClusterRoles to read  TempoStack tenants for  namespace
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: apc-tempo-stack-generate-tenant-clusterrole-read
    spec:
      background: true
      rules:
        - generate:
            apiVersion: rbac.authorization.k8s.io/v1
            data:
              metadata:
                labels:
                  generated-by: generate-reader-clusterrole-for-application-namespace
              rules:
                - apiGroups:
                    - tempo.grafana.com
                  resourceNames:
                    - traces
                  resources:
                    - '{{request.object.metadata.name}}'
                  verbs:
                    - get
            generateExisting: true
            kind: ClusterRole
            name: apc-tempo-stack-reader-{{request.object.metadata.name}}
            synchronize: true
          match:
            any:
              - resources:
                  kinds:
                    - Namespace
                  selector:
                    matchLabels:
                      apc.namespace.type: application
          name: generate-clusterrole-reader-for-application-namespace
      validationFailureAction: Audit
  3: |
    apiVersion: kyverno.io/v1
    kind: ClusterPolicy
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: Replace=true
        policies.kyverno.io/category: gitops
        policies.kyverno.io/minversion: 1.13.0
        policies.kyverno.io/subject: Generate ClusterRoles for application namespaces
        policies.kyverno.io/title: Generate ClusterRoles to write into TempoStack tenants for  namespace
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: apc-tempo-stack-generate-tenant-clusterrole-write
    spec:
      background: true
      rules:
        - generate:
            apiVersion: rbac.authorization.k8s.io/v1
            data:
              metadata:
                labels:
                  generated-by: generate-writer-clusterrole-for-application-namespace
                  rbac.authorization.k8s.io/apc-opentelemetry-collector-apc-observability-cluster-role: "true"
              rules:
                - apiGroups:
                    - tempo.grafana.com
                  resourceNames:
                    - traces
                  resources:
                    - '{{request.object.metadata.name}}'
                  verbs:
                    - create
            generateExisting: true
            kind: ClusterRole
            name: apc-tempo-stack-writer-{{request.object.metadata.name}}
            synchronize: true
          match:
            any:
              - resources:
                  kinds:
                    - Namespace
                  selector:
                    matchLabels:
                      apc.namespace.type: application
          name: generate-clusterrole-writer-for-application-namespace
      validationFailureAction: Audit
  4: |
    apiVersion: kyverno.io/v1
    kind: ClusterPolicy
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: Replace=true
        policies.kyverno.io/category: gitops
        policies.kyverno.io/minversion: 1.13.0
        policies.kyverno.io/subject: Generate RoleBindings for application namespaces
        policies.kyverno.io/title: Generate RoleBindings for TempoStack traces access on namespace
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: apc-tempo-stack-generate-tenant-rolebindings-read
    spec:
      background: true
      rules:
        - generate:
            apiVersion: rbac.authorization.k8s.io/v1
            data:
              roleRef:
                apiGroup: rbac.authorization.k8s.io
                kind: ClusterRole
                name: apc-tempo-stack-reader-{{ request.object.metadata.name }}
              subjects:
                - kind: Group
                  name: APC-D-{{ request.object.metadata.name }}-PJA
                - kind: Group
                  name: APC-D-{{ request.object.metadata.name }}-DEV
            generateExisting: true
            kind: RoleBinding
            name: apc-tempo-stack-traces-read
            namespace: '{{ request.object.metadata.name }}'
            synchronize: true
          match:
            any:
              - resources:
                  kinds:
                    - Namespace
                  selector:
                    matchLabels:
                      apc.namespace.type: application
          name: generate-rolebinding-reader-for-application-namespace
      validationFailureAction: Audit
  5: |
    apiVersion: kyverno.io/v1
    kind: ClusterPolicy
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: Replace=true
        policies.kyverno.io/category: gitops
        policies.kyverno.io/minversion: 1.13.0
        policies.kyverno.io/subject: Cleanup TempoStack tenants
        policies.kyverno.io/title: Update TempoStack tenants on namespace delete
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: apc-tempo-stack-tempo-cleanup-tenants
    spec:
      mutateExistingOnPolicyUpdate: false
      rules:
        - match:
            any:
              - resources:
                  kinds:
                    - Namespace
                  operations:
                    - DELETE
                  selector:
                    matchLabels:
                      apc.namespace.type: application
          mutate:
            patchesJson6902: |-
              - op: remove
                path: "/spec/tenants/authentication/-"
                value:
                  tenantName: "{{ request.oldObject.metadata.name }}"
                  tenantId: "{{ request.oldObject.metadata.name }}"
            targets:
              - apiVersion: tempo.grafana.com/v1alpha1
                kind: TempoStack
                name: apc-tempo-stack
                namespace: NAMESPACE
          name: remove-tenant-from-tempostack-on-namespace-delete
  6: |
    apiVersion: kyverno.io/v1
    kind: ClusterPolicy
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: Replace=true
        policies.kyverno.io/category: gitops
        policies.kyverno.io/minversion: 1.13.0
        policies.kyverno.io/subject: Sync TempoStack tenants with namespaces
        policies.kyverno.io/title: Update TempoStack tenants on namespace create
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: apc-tempo-stack-tempo-sync-tenants
    spec:
      background: true
      mutateExistingOnPolicyUpdate: true
      rules:
        - context:
            - apiCall:
                default: []
                jmesPath: spec.tenants.authentication[*].tenantName
                method: GET
                urlPath: /apis/tempo.grafana.com/v1alpha1/namespaces/NAMESPACE/tempostacks/apc-tempo-stack
              name: tenantNames
          match:
            all:
              - resources:
                  kinds:
                    - Namespace
                  selector:
                    matchLabels:
                      apc.namespace.type: application
          mutate:
            mutateExistingOnPolicyUpdate: true
            patchesJson6902: |-
              - op: add
                path: "/spec/tenants/authentication/-"
                value:
                  tenantName: "{{ request.object.metadata.name }}"
                  tenantId: "{{ request.object.metadata.name }}"
            targets:
              - apiVersion: tempo.grafana.com/v1alpha1
                kind: TempoStack
                name: apc-tempo-stack
                namespace: NAMESPACE
          name: add-tenant-to-tempostack
          preconditions:
            all:
              - key: '{{ request.object.metadata.name }}'
                message: A tenant is added into tempo.
                operator: AnyNotIn
                value: '{{ tenantNames }}'
      validationFailureAction: Audit
  7: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
        rbac.kyverno.io/aggregate-to-admission-controller: "true"
      name: kyverno:admission-controller:kyverno-app-grafana
    rules:
      - apiGroups:
          - rbac.authorization.k8s.io
        resources:
          - rolebindings
        verbs:
          - get
  8: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
        rbac.kyverno.io/aggregate-to-background-controller: "true"
      name: kyverno:background-controller:kyverno-app-grafana
    rules:
      - apiGroups:
          - ""
        resources:
          - serviceaccounts
        verbs:
          - create
          - delete
          - get
          - update
      - apiGroups:
          - rbac.authorization.k8s.io
        resources:
          - clusterroles
        verbs:
          - create
          - delete
          - get
          - update
      - apiGroups:
          - ""
        resources:
          - cluster
        verbs:
          - create
          - delete
          - get
          - update
      - apiGroups:
          - tempo.grafana.com
        resources:
          - tempostacks
        verbs:
          - get
          - list
          - watch
          - update
          - patch
      - apiGroups:
          - rbac.authorization.k8s.io
        resources:
          - clusterroles
          - roles
        verbs:
          - get
          - list
          - watch
          - create
          - update
          - patch
          - bind
          - escalate
          - delete
  9: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: tempostack-traces-read
    rules:
      - apiGroups:
          - tempo.grafana.com
        resourceNames:
          - traces
          - metrics
        resources:
          - '*'
        verbs:
          - get
  10: |
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    metadata:
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: tempostack-traces-write
    rules:
      - apiGroups:
          - tempo.grafana.com
        resourceNames:
          - traces
          - metrics
        resources:
          - '*'
        verbs:
          - create
  11: |
    apiVersion: networking.k8s.io/v1
    kind: NetworkPolicy
    metadata:
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: allow-from-cluster-observability-operator
      namespace: NAMESPACE
    spec:
      ingress:
        - from:
            - namespaceSelector:
                matchLabels:
                  kubernetes.io/metadata.name: openshift-cluster-observability-operator
      podSelector: {}
      policyTypes:
        - Ingress
  12: |
    apiVersion: objectbucket.io/v1alpha1
    kind: ObjectBucketClaim
    metadata:
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: apc-tempo-stack
      namespace: NAMESPACE
    spec:
      bucketName: apc-tempo-stack
      storageClassName: ocs-storagecluster-ceph-rgw
  13: |
    apiVersion: tempo.grafana.com/v1alpha1
    kind: TempoStack
    metadata:
      labels:
        app.kubernetes.io/instance: kyverno-app-grafana
        app.kubernetes.io/managed-by: Helm
        app.kubernetes.io/name: openshift-distributed-tracing
        app.kubernetes.io/version: v0.15
        helm.sh/chart: openshift-distributed-tracing-1.0.0
      name: apc-tempo-stack
      namespace: NAMESPACE
    spec:
      observability:
        metrics:
          createPrometheusRules: true
          createServiceMonitors: true
      retention:
        global:
          traces: 48h0m0s
      storage:
        secret:
          name: apc-tempo-stack-allinfo
          type: s3
        tls:
          caName: openshift-service-ca.crt
          enabled: true
      storageSize: 200Mi
      template:
        compactor:
          resources:
            limits:
              cpu: 500m
              memory: 1Gi
            requests:
              cpu: 100m
              memory: 150Mi
        distributor:
          component:
            resources:
              limits:
                cpu: 750m
                memory: 1Gi
              requests:
                cpu: 200m
                memory: 200Mi
        gateway:
          component:
            resources:
              limits:
                cpu: 250m
                memory: 500Mi
              requests:
                cpu: 50m
                memory: 100Mi
          enabled: true
          ingress:
            type: route
        ingester:
          resources:
            limits:
              cpu: "1"
              memory: 1536Mi
            requests:
              cpu: 250m
              memory: 400Mi
        querier:
          resources:
            limits:
              cpu: 500m
              memory: 500Mi
            requests:
              cpu: 100m
              memory: 100Mi
        queryFrontend:
          component:
            resources:
              limits:
                cpu: 250m
                memory: 500Mi
              requests:
                cpu: 50m
                memory: 100Mi
          jaegerQuery:
            enabled: true
            resources:
              limits:
                cpu: 250m
                memory: 500Mi
              requests:
                cpu: 50m
                memory: 100Mi
            tempoQuery:
              resources:
                limits:
                  cpu: 250m
                  memory: 500Mi
                requests:
                  cpu: 50m
                  memory: 100Mi
      tenants:
        authentication:
          - tenantId: application
            tenantName: application
        mode: openshift
