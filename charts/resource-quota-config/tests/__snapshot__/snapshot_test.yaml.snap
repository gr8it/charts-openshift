manifests should match snapshot:
  1: |
    apiVersion: v1
    kind: LimitRange
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: ServerSideApply=true
      name: default-limit-range
      namespace: sktst
    spec:
      limits:
        - default:
            cpu: 200m
            ephemeral-storage: 1Gi
            memory: 200Mi
          defaultRequest:
            cpu: 50m
            memory: 50Mi
          type: Container
  2: |
    apiVersion: v1
    kind: ResourceQuota
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: ServerSideApply=true
      name: default-resource-quota
      namespace: eds
    spec:
      hard:
        limits.cpu: "12"
        limits.memory: 60Gi
        requests.cpu: "6"
        requests.memory: 40Gi
        services.loadbalancers: "3"
  3: |
    apiVersion: v1
    kind: ResourceQuota
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: ServerSideApply=true
      name: cnpg-custom-resource-quota
      namespace: sktst
    spec:
      hard:
        count/backups.postgresql.cnpg.io: "25"
  4: |
    apiVersion: v1
    kind: ResourceQuota
    metadata:
      annotations:
        argocd.argoproj.io/sync-options: ServerSideApply=true
      name: default-resource-quota
      namespace: sktst
    spec:
      hard:
        limits.cpu: "6"
        limits.memory: 35Gi
        persistentvolumeclaims: "30"
        pods: "10"
        requests.cpu: "3"
        requests.memory: 25Gi
        services.loadbalancers: "1"
